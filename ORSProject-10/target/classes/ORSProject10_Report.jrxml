	<queryString language="SQL">
		<![CDATA[SELECT ROLL_NO, NAME, PHYSICS, CHEMISTRY, MATHS, 
			(PHYSICS + CHEMISTRY + MATHS) AS total 
			FROM st_marksheet 
			WHERE PHYSICS > 33 AND CHEMISTRY > 33 AND MATHS > 33 
			ORDER BY total DESC 
			LIMIT 0,10]]>
	</queryString>
